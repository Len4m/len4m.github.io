      vsMinimax: "vs minimax",
    },
  };
  const MODEL_STORAGE_URL = "indexeddb://tic-tac-toe-ml-model";
  const APP_DB_NAME = "tic-tac-toe-ml-app";
  const APP_DB_VERSION = 1;
  const DATASET_STORE = "datasetChunks";
  const META_STORE = "meta";
  const DATASET_CHUNK_SIZE = 250;

  function openAppDb() {
    return new Promise((resolve, reject) => {
      const request = indexedDB.open(APP_DB_NAME, APP_DB_VERSION);
      request.onupgradeneeded = () => {
        const db = request.result;
        if (!db.objectStoreNames.contains(DATASET_STORE)) {
          db.createObjectStore(DATASET_STORE, { keyPath: "key" });
        }
        if (!db.objectStoreNames.contains(META_STORE)) {
          db.createObjectStore(META_STORE, { keyPath: "key" });
        }
      };
      request.onsuccess = () => resolve(request.result);
      request.onerror = () => reject(request.error);
    });
  }

  async function clearStore(db, storeName) {
    return new Promise((resolve, reject) => {
      const tx = db.transaction(storeName, "readwrite");
      tx.objectStore(storeName).clear();
      tx.oncomplete = () => resolve();
      tx.onerror = () => reject(tx.error);
    });
  }

  async function putMeta(db, key, value) {
    return new Promise((resolve, reject) => {
      const tx = db.transaction(META_STORE, "readwrite");
      tx.objectStore(META_STORE).put({ key, value });
      tx.oncomplete = () => resolve();
      tx.onerror = () => reject(tx.error);
    });
  }

  async function getMeta(db, key) {
    return new Promise((resolve, reject) => {
      const tx = db.transaction(META_STORE, "readonly");
      const req = tx.objectStore(META_STORE).get(key);
      req.onsuccess = () => resolve(req.result?.value ?? null);
      req.onerror = () => reject(req.error);
    });
  }

  async function saveDatasetToDb(dataset) {
    const db = await openAppDb();
    await clearStore(db, DATASET_STORE);
    await putMeta(db, "datasetCount", dataset.length);
    await putMeta(db, "datasetChunkSize", DATASET_CHUNK_SIZE);
    const chunks = [];
    for (let i = 0; i < dataset.length; i += DATASET_CHUNK_SIZE) {
      chunks.push({
        key: `chunk-${Math.floor(i / DATASET_CHUNK_SIZE)}`,
        items: dataset.slice(i, i + DATASET_CHUNK_SIZE),
      });
    }
    await new Promise((resolve, reject) => {
      const tx = db.transaction(DATASET_STORE, "readwrite");
      const store = tx.objectStore(DATASET_STORE);
      chunks.forEach((chunk) => store.put(chunk));
      tx.oncomplete = () => resolve();
      tx.onerror = () => reject(tx.error);
    });
    db.close();
  }

  async function getDatasetChunkCountFromDb() {
    const db = await openAppDb();
    const count = await getMeta(db, "datasetCount");
    const chunkSize = await getMeta(db, "datasetChunkSize");
    db.close();
    if (!count || !chunkSize) return 0;
    return Math.ceil(count / chunkSize);
  }

  async function loadDatasetChunkByIndex(index) {
    const db = await openAppDb();
    const chunk = await new Promise((resolve, reject) => {
      const tx = db.transaction(DATASET_STORE, "readonly");
      const req = tx.objectStore(DATASET_STORE).get(`chunk-${index}`);
      req.onsuccess = () => resolve(req.result?.items ?? []);
      req.onerror = () => reject(req.error);
    });
    db.close();
    return chunk;
  }

  async function getDatasetCountFromDb() {
    const db = await openAppDb();
    const count = await getMeta(db, "datasetCount");
    db.close();
    return count ?? 0;
  }

  const WORKER_SOURCE = `
    importScripts('${TFJS_URL}');

    async function ensureTfReady() {
      await tf.setBackend('cpu');
      await tf.ready();
    }

    class TinyPolicyNetwork {
      constructor() {
        this.model = null;
        this.createModel();
      }

      createModel() {
        if (this.model) this.model.dispose();
        const model = tf.sequential();
        model.add(tf.layers.dense({ inputShape: [10], units: 24, activation: 'relu' }));
        model.add(tf.layers.dense({ units: 9, activation: 'softmax' }));
        model.compile({ optimizer: tf.train.adam(0.02), loss: 'categoricalCrossentropy', metrics: ['accuracy'] });
        this.model = model;
      }

      predict(x) {
        return tf.tidy(() => {
          const xs = tf.tensor2d([x], [1, 10]);
          const pred = this.model.predict(xs);
          return Array.from(pred.dataSync());
        });
      }

      async train(dataset, epochs = 30, lr = 0.02, batchSize = 64, onBatchEnd = null, onEpochEnd = null, shouldStop = () => false) {
        await ensureTfReady();
        this.model.compile({ optimizer: tf.train.adam(lr), loss: 'categoricalCrossentropy', metrics: ['accuracy'] });
        const indices = dataset.map((_, index) => index);
        const shuffle = (arr) => {
          for (let i = arr.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [arr[i], arr[j]] = [arr[j], arr[i]];
          }
        };
        const totalBatches = Math.max(1, Math.ceil(dataset.length / batchSize));
        if (onBatchEnd) onBatchEnd({ batch: 0, totalBatches, loss: 0, accuracy: 0 });

        for (let epoch = 0; epoch < epochs; epoch++) {
          if (shouldStop()) break;
          shuffle(indices);
          let epochLoss = 0;
          let epochAcc = 0;
          let seenBatches = 0;

          for (let batchIndex = 0; batchIndex < totalBatches; batchIndex++) {
            if (shouldStop()) break;
            const batchIndices = indices.slice(batchIndex * batchSize, (batchIndex + 1) * batchSize);
            const batchX = batchIndices.map((idx) => dataset[idx].x);
            const batchY = batchIndices.map((idx) => dataset[idx].target);

            const xs = tf.tensor2d(batchX, [batchX.length, 10]);
            const ys = tf.tensor2d(batchY, [batchY.length, 9]);
            let metrics;
            try {
              metrics = await this.model.trainOnBatch(xs, ys);
            } finally {
              xs.dispose();
              ys.dispose();
            }

            const metricArray = Array.isArray(metrics) ? metrics : [metrics];
            const batchLoss = Number(metricArray[0] ?? 0);
            const batchAcc = Number(metricArray[1] ?? 0);
            epochLoss += batchLoss;
            epochAcc += batchAcc;
            seenBatches += 1;

            if (onBatchEnd) {
              onBatchEnd({ batch: batchIndex + 1, totalBatches, loss: batchLoss, accuracy: batchAcc });
            }
            await tf.nextFrame();
          }

          if (seenBatches > 0 && onEpochEnd) {
            onEpochEnd({ epoch, avgLoss: epochLoss / seenBatches, accuracy: epochAcc / seenBatches, totalBatches });
          }
          await tf.nextFrame();
        }
      }

      getState() {
        return this.model.getWeights().map((tensor) => ({ shape: tensor.shape, data: Array.from(tensor.dataSync()) }));
      }

      setState(snapshot) {
        if (!snapshot || !snapshot.length) return;
        const tensors = snapshot.map((item) => tf.tensor(item.data, item.shape));
        this.model.setWeights(tensors);
        tensors.forEach((tensor) => tensor.dispose());
      }
    }

    function getAvailableMoves(board) {
      const out = [];
      for (let i = 0; i < board.length; i++) if (!board[i]) out.push(i);
      return out;
    }

    function checkWinner(board) {
      const lines = [[0,1,2],[3,4,5],[6,7,8],[0,3,6],[1,4,7],[2,5,8],[0,4,8],[2,4,6]];
      for (const [a,b,c] of lines) if (board[a] && board[a] === board[b] && board[b] === board[c]) return board[a];
      return board.every(Boolean) ? 'draw' : null;
    }

    function otherPlayer(player) { return player === 'X' ? 'O' : 'X'; }

    function minimax(board, current, maximizingPlayer, depth = 0) {
      const result = checkWinner(board);
      if (result) {
        if (result === maximizingPlayer) return 10 - depth;
        if (result === 'draw') return 0;
        return depth - 10;
      }
      const moves = getAvailableMoves(board);
      const isMax = current === maximizingPlayer;
      let best = isMax ? -Infinity : Infinity;
      for (const move of moves) {
        board[move] = current;
        const score = minimax(board, otherPlayer(current), maximizingPlayer, depth + 1);
        board[move] = '';
        if (isMax) best = Math.max(best, score);
        else best = Math.min(best, score);
      }
      return best;
    }

    function getImmediateWinningMoves(board, player) {
      const wins = [];
      const moves = getAvailableMoves(board);
      for (const move of moves) {
        board[move] = player;
        if (checkWinner(board) === player) wins.push(move);
        board[move] = '';
      }
      return wins;
    }

    function bestMoveMinimax(board, player) {
      const moves = getAvailableMoves(board);
      if (!moves.length) return null;
      const immediateWins = getImmediateWinningMoves(board, player);
      if (immediateWins.length) return immediateWins[0];
      const opponent = otherPlayer(player);
      const forcedBlocks = getImmediateWinningMoves(board, opponent);
      if (forcedBlocks.length) return forcedBlocks[0];
      let bestScore = -Infinity;
      let bestMove = moves[0];
      for (const move of moves) {
        board[move] = player;
        const score = minimax(board, opponent, player, 1);
        board[move] = '';
        if (score > bestScore) {
          bestScore = score;
          bestMove = move;
        }
      }
      return bestMove;
    }

    function encodeBoard(board, playerToMove = 'O') {
      const current = board.map((cell) => cell === 'X' ? -1 : cell === 'O' ? 1 : 0);
      current.push(playerToMove === 'O' ? 1 : -1);
      return current;
    }

    function argmaxLegal(probs, board) {
      const legal = getAvailableMoves(board);
      let best = legal[0] ?? null;
      let score = -Infinity;
      for (const idx of legal) if (probs[idx] > score) { score = probs[idx]; best = idx; }
      return best;
    }

    function isValidStateForOTurn(board) {
      const xCount = board.filter((cell) => cell === 'X').length;
      const oCount = board.filter((cell) => cell === 'O').length;
      return xCount === oCount + 1 && !checkWinner(board);
    }

    function randomInt(max) {
      return Math.floor(Math.random() * max);
    }

    function boardKey(board) {
      return board.join('|');
    }

    function buildSampleFromBoard(board) {
      const legal = getAvailableMoves(board);
      if (!legal.length) return null;
      const moveScores = legal.map((move) => {
        board[move] = 'O';
        const score = minimax(board, 'X', 'O', 1);
        board[move] = '';
        return { move, score };
      });
      const bestScore = Math.max(...moveScores.map((entry) => entry.score));
      const bestMoves = moveScores.filter((entry) => entry.score === bestScore).map((entry) => entry.move);
      if (!bestMoves.length) return null;
      const target = Array(9).fill(0);
      const weight = 1 / bestMoves.length;
      bestMoves.forEach((move) => { target[move] = weight; });
      return { x: encodeBoard(board, 'O'), y: bestMoves[0], target, board: board.slice(), bestMoveCount: bestMoves.length, bestScore };
    }

    function generateRandomValidBoardForOTurn(maxPlies = 5) {
      const board = Array(9).fill('');
      let current = 'X';
      const pliesOptions = [1, 3, 5];
      const plies = pliesOptions[randomInt(pliesOptions.length)];
      for (let step = 0; step < Math.min(maxPlies, plies); step++) {
        const winner = checkWinner(board);
        if (winner) break;
        const options = getAvailableMoves(board);
        if (!options.length) break;
        const move = options[randomInt(options.length)];
        board[move] = current;
        current = otherPlayer(current);
      }
      return isValidStateForOTurn(board) ? board : null;
    }

    function shuffle(arr) {
      for (let i = arr.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [arr[i], arr[j]] = [arr[j], arr[i]];
      }
      return arr;
    }

    function createTacticalBoards(limit = 300) {
      const boards = [];
      const seen = new Set();
      let attempts = 0;
      const maxAttempts = limit * 80;
      while (boards.length < limit && attempts < maxAttempts) {
        attempts += 1;
        const board = generateRandomValidBoardForOTurn(5);
        if (!board) continue;
        const sample = buildSampleFromBoard(board.slice());
        const opponentWins = getImmediateWinningMoves(board.slice(), 'X');
        const selfWins = getImmediateWinningMoves(board.slice(), 'O');
        const isTactical = selfWins.length > 0 || opponentWins.length > 0 || (sample && sample.bestMoveCount === 1);
        const key = boardKey(board);
        if (!isTactical || seen.has(key)) continue;
        seen.add(key);
        boards.push(board.slice());
        if (boards.length % 50 === 0) postMessage({ type: 'dataset-progress', generated: boards.length, target: limit });
      }
      return boards;
    }

    function generateTrainingData(count = 600) {
      const targetCount = Math.max(50, count);
      const samples = [];
      const seen = new Set();
      const tacticalBoards = shuffle(createTacticalBoards(Math.min(600, Math.max(80, Math.floor(targetCount * 0.4)))));
      const tacticalQuota = Math.min(tacticalBoards.length, Math.max(80, Math.floor(targetCount * 0.4)));

      for (let i = 0; i < tacticalQuota && samples.length < targetCount; i++) {
        const board = tacticalBoards[i].slice();
        const key = boardKey(board);
        if (seen.has(key)) continue;
        const sample = buildSampleFromBoard(board);
        if (!sample) continue;
        seen.add(key);
        samples.push(sample);
        if (samples.length % 100 === 0) postMessage({ type: 'dataset-progress', generated: samples.length, target: targetCount });
      }

      let attempts = 0;
      const maxAttempts = targetCount * 120;
      while (samples.length < targetCount && attempts < maxAttempts) {
        attempts += 1;
        const board = generateRandomValidBoardForOTurn();
        if (!board) continue;
        const key = boardKey(board);
        if (seen.has(key)) continue;
        const sample = buildSampleFromBoard(board);
        if (!sample) continue;
        seen.add(key);
        samples.push(sample);
        if (samples.length % 100 === 0 || samples.length === targetCount) {
          postMessage({ type: 'dataset-progress', generated: samples.length, target: targetCount });
        }
      }

      return shuffle(samples).slice(0, targetCount);
    }

    let stopped = false;
    onmessage = async (event) => {
      const { type, count, dataset, epochs, lr, rounds, opponent, modelState, batchSize } = event.data;
      if (type === 'stop') { stopped = true; return; }

      if (type === 'generate-dataset') {
        stopped = false;
        const samples = generateTrainingData(count);
        postMessage({ type: 'dataset-ready', dataset: samples });
        return;
      }

      if (type === 'train') {
        stopped = false;
        await ensureTfReady();
        const model = new TinyPolicyNetwork();
        if (modelState) model.setState(modelState);
        let lastSnapshot = model.getState();
        await model.train(
          dataset,
          epochs,
          lr,
          batchSize,
          ({ batch, totalBatches, loss, accuracy }) => {
            postMessage({ type: 'batch-progress', batch, totalBatches, loss, accuracy, ts: Date.now() });
          },
          ({ epoch, avgLoss, accuracy, totalBatches }) => {
            lastSnapshot = model.getState();
            postMessage({ type: 'epoch', epoch: epoch + 1, avgLoss, accuracy, totalBatches, modelState: lastSnapshot });
          },
          () => stopped
        );
        postMessage({ type: 'training-finished', stopped, modelState: lastSnapshot });
        return;
      }

      if (type === 'evaluate') {
        stopped = false;
        await ensureTfReady();
        const model = new TinyPolicyNetwork();
        if (modelState) model.setState(modelState);
        const tally = { wins: 0, draws: 0, losses: 0 };
        function bestMoveModel(board, player = 'O') {
          const x = encodeBoard(board, player);
          const probs = model.predict(x);
          return argmaxLegal(probs, board);
        }
        function playAutomatedMatch(matchOpponent) {
          const board = Array(9).fill('');
          let current = 'X';
          while (true) {
            const result = checkWinner(board);
            if (result) return result;
            let move;
            if (current === 'O') move = bestMoveModel(board, 'O');
            else if (matchOpponent === 'minimax') move = bestMoveMinimax(board, 'X');
            else {
              const options = getAvailableMoves(board);
              move = options[Math.floor(Math.random() * options.length)] ?? null;
            }
            if (move == null) return checkWinner(board) || 'draw';
            board[move] = current;
            current = otherPlayer(current);
          }
        }
        for (let i = 0; i < rounds; i++) {
          if (stopped) break;
          const result = playAutomatedMatch(opponent);
          if (result === 'O') tally.wins += 1;
          else if (result === 'draw') tally.draws += 1;
          else tally.losses += 1;
        }
        postMessage({ type: 'evaluation-finished', tally, opponent });
      }
    };
  `;

  class TinyPolicyNetwork {
    constructor() {
      this.model = null;
      this.reset();
    }

    reset() {
      if (this.model) this.model.dispose();
      const model = tf.sequential();
      model.add(tf.layers.dense({ inputShape: [10], units: 24, activation: "relu" }));
      model.add(tf.layers.dense({ units: 9, activation: "softmax" }));
      model.compile({
        optimizer: tf.train.adam(0.02),
        loss: "categoricalCrossentropy",
        metrics: ["accuracy"],
      });
      this.model = model;
    }

    predict(x) {
      return tf.tidy(() => {
        const xs = tf.tensor2d([x], [1, 10]);
        const pred = this.model.predict(xs);
        return Array.from(pred.dataSync());
      });
    }

    getState() {
      return this.model.getWeights().map((tensor) => ({
        shape: tensor.shape,
        data: Array.from(tensor.dataSync()),
      }));
    }

    setState(snapshot) {
      if (!snapshot || !snapshot.length) return;
      const tensors = snapshot.map((item) => tf.tensor(item.data, item.shape));
      this.model.setWeights(tensors);
      tensors.forEach((tensor) => tensor.dispose());
    }

    async save(url = MODEL_STORAGE_URL) {
      await this.model.save(url);
    }

    async load(url = MODEL_STORAGE_URL) {
      try {
        const loadedModel = await tf.loadLayersModel(url);
        if (this.model) this.model.dispose();
        this.model = loadedModel;
        this.model.compile({
          optimizer: tf.train.adam(0.02),
          loss: "categoricalCrossentropy",
          metrics: ["accuracy"],
        });
        return true;
      } catch {
        return false;
      }
    }
  }

