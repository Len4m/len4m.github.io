      generatingDataset: "Generating dataset…",
      datasetGenerated: (n) => `Dataset generated and saved with ${n} examples.`,
      noDataset: "There is no persisted dataset available for training.",
      trainingFromDb: "Training by chunks from IndexedDB…",
      trainingBatch: (a, b) => `Training… batch ${a}/${b}`,
      trainingEpoch: (n) => `Training… epoch ${n}`,
      trainingWorkerError: (msg) => `Training worker error: ${msg || "unknown"}`,
      trainingStoppedSaved: "Training stopped and saved. You can resume it.",
      trainingFinishedSaved: "Training finished and saved.",
      draw: "Draw.",
      winsGame: (w) => `${w} wins.`,
      aiMoveTurn: "AI turn.",
      yes: "yes",
      no: "no",
      memory: "memory",
      none: "none",
      evaluatingAgainst: (o) => `Evaluating against ${o}…`,
      evaluationCompleted: (o) => `Evaluation completed against ${o}.`,
