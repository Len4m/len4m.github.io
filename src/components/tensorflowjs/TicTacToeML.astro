    ensureAudioContext() {
      if (!this.audioCtx) {
        const AudioCtx = window.AudioContext || window.webkitAudioContext;
        if (!AudioCtx) return null;
        this.audioCtx = new AudioCtx();
      }
      if (this.audioCtx.state === "suspended") {
        this.audioCtx.resume().catch(() => {});
      }
      return this.audioCtx;
    }

    playTone(frequency, duration, type = "square", volume = 0.18, startTime = null) {
      const audioCtx = this.ensureAudioContext();
      if (!audioCtx) return;
      const now = startTime ?? audioCtx.currentTime;
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.type = type;
      osc.frequency.setValueAtTime(frequency, now);
      gain.gain.setValueAtTime(0.0001, now);
      gain.gain.linearRampToValueAtTime(volume, now + 0.01);
      gain.gain.exponentialRampToValueAtTime(0.001, now + duration);
      osc.connect(gain);
      gain.connect(audioCtx.destination);
      osc.start(now);
      osc.stop(now + duration);
    }

    playWinSound() {
      const audioCtx = this.ensureAudioContext();
      if (!audioCtx) return;
      const now = audioCtx.currentTime;
      this.playTone(659.25, 0.08, "square", 0.16, now);
      this.playTone(783.99, 0.08, "square", 0.16, now + 0.09);
      this.playTone(987.77, 0.12, "square", 0.18, now + 0.18);
      this.playTone(1318.51, 0.2, "square", 0.2, now + 0.31);
    }

    playLoseSound() {
      const audioCtx = this.ensureAudioContext();
      if (!audioCtx) return;
      const now = audioCtx.currentTime;
      this.playTone(440.0, 0.08, "square", 0.16, now);
      this.playTone(369.99, 0.08, "square", 0.16, now + 0.09);
      this.playTone(293.66, 0.12, "square", 0.17, now + 0.18);
      this.playTone(220.0, 0.2, "square", 0.18, now + 0.31);
    }

    maybePlayGameEndSound(winner) {
      if (
        this.state.demoMode ||
        this.isTraining ||
        this.isGeneratingDataset ||
        this.state.isEvaluating
      ) {
        return;
      }
      if (winner === this.state.humanSymbol) {
        this.playWinSound();
      } else if (winner && winner !== "draw") {
        this.playLoseSound();
      }
    }

    formatBytes(bytes) {
      if (!Number.isFinite(bytes) || bytes <= 0) return "0 B";
      const units = ["B", "KB", "MB", "GB"];
      let value = bytes;
      let unitIndex = 0;
      while (value >= 1024 && unitIndex < units.length - 1) {
        value /= 1024;
        unitIndex += 1;
      }
      return `${value >= 100 || unitIndex === 0 ? value.toFixed(0) : value.toFixed(1)} ${units[unitIndex]}`;
    }

    getModelSizeBytes() {
      return this.model
        .getState()
        .reduce((total, item) => total + (item.data?.length || 0) * 4, 0);
    }

    async saveModelToIndexedDb(fromTraining = false) {
      if (!fromTraining && (this.isTraining || this.isGeneratingDataset || this.state.isEvaluating)) {
        return;
      }
      await this.model.save(MODEL_STORAGE_URL);
      this.state.modelPersisted = true;
      if (!fromTraining) this.state.status = this.t.modelSaved;
      this.updateUI();
    }

    async resetModel() {
      this.stopWorkers();
      this.model.reset();
      this.state.losses = [];
      this.state.accuracies = [];
      this.state.epochsCompleted = 0;
      this.state.currentBatch = 0;
      this.state.totalBatches = 0;
      this.state.latestBatchLoss = 0;
      this.state.latestBatchAcc = 0;
      this.state.modelPersisted = false;
      this.state.status = this.t.modelReset;
      this.updateUI();
    }

    stopWorkers() {
      if (this.trainingWorker) {
        this.trainingWorker.postMessage({ type: "stop" });
        this.trainingWorker.terminate();
        this.trainingWorker = null;
      }
      if (this.datasetWorker) {
        this.datasetWorker.postMessage({ type: "stop" });
        this.datasetWorker.terminate();
        this.datasetWorker = null;
      }
      if (this.evaluationWorker) {
        this.evaluationWorker.postMessage({ type: "stop" });
        this.evaluationWorker.terminate();
        this.evaluationWorker = null;
      }
      this.stopDemoPlayback();
      this.isTraining = false;
      this.activeTrainingSessionId = null;
      this.isGeneratingDataset = false;
      this.state.isEvaluating = false;
      if (!this.state.gameOver) {
        this.state.status = this.t.processStopped;
      }
      this.updateUI();
    }

    async generateDatasetInWorker(count) {
      if (this.isTraining || this.isGeneratingDataset || this.state.isEvaluating) {
        return false;
      }
      this.isGeneratingDataset = true;
      this.state.status = this.t.generatingDataset;
      this.updateUI();
      return new Promise((resolve) => {
        this.datasetWorker = this.createWorker();
        this.datasetWorker.onmessage = async (event) => {
          const { type, generated, target, dataset } = event.data;
          if (type === "dataset-progress") {
            this.state.status = `${this.t.generatingDataset} ${generated}/${target}`;
            this.updateUI();
          }
          if (type === "dataset-ready") {
            this.state.trainingSet = [];
            this.state.trainingSetPersistedCount = dataset.length;
            this.state.trainingChunkCount = Math.ceil(dataset.length / DATASET_CHUNK_SIZE);
            this.state.totalRowsGenerated = dataset.length;
            await saveDatasetToDb(dataset);
            this.isGeneratingDataset = false;
            if (this.datasetWorker) {
              this.datasetWorker.terminate();
              this.datasetWorker = null;
            }
            this.state.status = this.t.datasetGenerated(dataset.length);
            this.updateUI();
            resolve(true);
          }
        };
        this.datasetWorker.postMessage({ type: "generate-dataset", count });
      });
    }

    async ensureDatasetLoaded() {
      const persistedCount = await getDatasetCountFromDb();
      this.state.trainingSetPersistedCount = persistedCount;
      this.state.trainingChunkCount = await getDatasetChunkCountFromDb();
      return persistedCount > 0;
    }

    async startTraining() {
      if (this.isTraining || this.isGeneratingDataset || this.state.isEvaluating) return;
      let hasDataset = await this.ensureDatasetLoaded();
      if (!hasDataset) {
        const fallbackCount = this.$datasetSize ? Number(this.$datasetSize.value) : 600;
        hasDataset = await this.generateDatasetInWorker(fallbackCount);
        if (!hasDataset) return;
      }

      const chunkCount = this.state.trainingChunkCount || (await getDatasetChunkCountFromDb());
      const totalRows = this.state.trainingSetPersistedCount || (await getDatasetCountFromDb());
      if (!chunkCount || !totalRows) {
        this.state.status = this.t.noDataset;
        this.updateUI();
        return;
      }

      this.isTraining = true;
      this.state.demoMode = true;
      this.state.currentBatch = 0;
      this.state.totalRequestedEpochs = this.state.epochsCompleted + 30;
      this.state.totalBatches = Math.max(1, Math.ceil(totalRows / this.state.batchSize));
      this.state.status = this.t.trainingFromDb;
      this.updateUI();
      this.playTrainingDemo();

      const sessionId = Date.now();
      this.activeTrainingSessionId = sessionId;

      if (this.trainingWorker) {
        this.trainingWorker.terminate();
        this.trainingWorker = null;
      }

      const workerRef = this.createWorker();
      this.trainingWorker = workerRef;

      workerRef.onerror = (error) => {
        if (this.activeTrainingSessionId !== sessionId) return;
        this.isTraining = false;
        this.state.status = this.t.trainingWorkerError(error.message);
        if (this.trainingWorker === workerRef) this.trainingWorker = null;
        try {
          workerRef.terminate();
        } catch {}
        this.updateUI();
      };

      let currentModelState = this.model.getState();
      let stopRequested = false;
      let epochLossAccumulator = 0;
      let epochAccAccumulator = 0;
      let epochBatchesSeen = 0;

      const runChunk = async (chunkDataset, batchOffset) => {
        return new Promise((resolve) => {
          const onMessage = (event) => {
            if (this.activeTrainingSessionId !== sessionId) return;
            const { type, modelState, stopped, batch, loss, accuracy, ts } = event.data;

            if (type === "batch-progress") {
              const effectiveBatch = Math.max(0, batch ?? 0);
              this.state.currentBatch = Math.min(this.state.totalBatches, batchOffset + effectiveBatch);
              this.state.latestBatchLoss = Number(loss ?? 0);
              this.state.latestBatchAcc = Number(accuracy ?? 0);
              this.state.status = this.t.trainingBatch(this.state.currentBatch, this.state.totalBatches);
              this.state.lastBatchEventAt = ts ?? Date.now();
              if (effectiveBatch > 0) {
                epochLossAccumulator += Number(loss ?? 0);
                epochAccAccumulator += Number(accuracy ?? 0);
                epochBatchesSeen += 1;
              }
              this.updateUI();
            }

            if (type === "training-finished") {
              workerRef.removeEventListener("message", onMessage);
              if (modelState) {
                currentModelState = modelState;
                this.model.setState(modelState);
              }
              stopRequested = !!stopped;
              resolve({ stopped });
            }
          };

          workerRef.addEventListener("message", onMessage);
          workerRef.postMessage({
            type: "train",
            dataset: chunkDataset,
            epochs: 1,
            lr: 0.02,
            batchSize: this.state.batchSize,
            modelState: currentModelState,
          });
        });
      };

      try {
        for (let epochIndex = 0; epochIndex < 30; epochIndex++) {
          if (!this.isTraining || this.activeTrainingSessionId !== sessionId) break;
          epochLossAccumulator = 0;
          epochAccAccumulator = 0;
          epochBatchesSeen = 0;
          this.state.currentBatch = 0;
          this.updateUI();

          for (let chunkIndex = 0; chunkIndex < chunkCount; chunkIndex++) {
            if (!this.isTraining || this.activeTrainingSessionId !== sessionId) break;
            const batchOffset = Math.floor((chunkIndex * DATASET_CHUNK_SIZE) / this.state.batchSize);
            const chunkDataset = await loadDatasetChunkByIndex(chunkIndex);
            if (!chunkDataset.length) continue;
            const result = await runChunk(chunkDataset, batchOffset);
            if (result.stopped) break;
          }

          if (epochBatchesSeen > 0) {
            const avgLoss = epochLossAccumulator / epochBatchesSeen;
            const avgAcc = epochAccAccumulator / epochBatchesSeen;
            this.state.losses.push(avgLoss);
            this.state.accuracies.push(avgAcc);
            if (this.state.losses.length > 40) this.state.losses.shift();
            if (this.state.accuracies.length > 40) this.state.accuracies.shift();
            this.state.epochsCompleted += 1;
            this.state.currentBatch = this.state.totalBatches;
            this.state.status = this.t.trainingEpoch(this.state.epochsCompleted);
            this.updateUI();
            await this.saveModelToIndexedDb(true);
          }

          if (stopRequested || !this.isTraining || this.activeTrainingSessionId !== sessionId) {
            break;
          }
        }
      } finally {
        if (this.activeTrainingSessionId === sessionId) {
          this.isTraining = false;
          if (this.trainingWorker === workerRef) this.trainingWorker = null;
          try {
            workerRef.terminate();
          } catch {}
          this.state.status = stopRequested
            ? this.t.trainingStoppedSaved
            : this.t.trainingFinishedSaved;
          if (!stopRequested && this.state.demoMode) this.state.demoShouldFinishCycle = true;
          else if (stopRequested) this.stopDemoPlayback();
          this.updateUI();
        }
      }
    }

    resetGame() {
      this.state.board = Array(9).fill("");
      this.state.currentPlayer = "X";
      this.state.gameOver = false;
      this.state.winner = null;
      this.state.status = this.t.yourTurn;
      this.updateUI();
    }

    updateUI() {
      if (!this.elementsReady()) return;
      this.$datasetSizeValue.textContent = this.$datasetSize ? this.$datasetSize.value : "600";
      if (this.$batchSize) this.$batchSize.value = String(this.state.batchSize);
      this.$batchSizeValue.textContent = String(this.state.batchSize);
      this.$epochCount.textContent = String(this.state.epochsCompleted);
      this.$datasetCount.textContent = String(this.state.trainingSetPersistedCount);
      this.$persistedValue.textContent = this.state.modelPersisted ? this.t.yes : this.t.no;
      this.$modelSizeValue.textContent = this.formatBytes(this.getModelSizeBytes());
      this.$datasetPersistedValue.textContent = String(this.state.trainingSetPersistedCount);
      this.$aiLabel.textContent = this.t.model;
      this.$status.textContent = this.state.status;
      this.$lossValue.textContent = this.state.losses.length
        ? this.state.losses[this.state.losses.length - 1].toFixed(4)
        : "-";
      this.$accValue.textContent = this.state.accuracies.length
        ? `${(this.state.accuracies[this.state.accuracies.length - 1] * 100).toFixed(1)}%`
        : "-";
      this.$batchLossValue.textContent = this.state.latestBatchLoss
        ? this.state.latestBatchLoss.toFixed(4)
        : "-";
      this.$batchAccValue.textContent = this.state.latestBatchAcc
        ? `${(this.state.latestBatchAcc * 100).toFixed(1)}%`
        : "-";
      this.$batchCounter.textContent = `${this.state.currentBatch}/${this.state.totalBatches}`;
      this.$batchProgress.style.width = `${this.state.totalBatches ? (this.state.currentBatch / this.state.totalBatches) * 100 : 0}%`;
      this.$evalWins.textContent = String(this.state.eval.wins);
      this.$evalDraws.textContent = String(this.state.eval.draws);
      this.$evalLosses.textContent = String(this.state.eval.losses);
      this.$generateBtn.disabled = this.isTraining || this.isGeneratingDataset || this.state.isEvaluating;
      this.$trainBtn.disabled = this.isTraining || this.isGeneratingDataset || this.state.isEvaluating;
      this.$stopBtn.disabled = !this.isTraining && !this.isGeneratingDataset && !this.state.isEvaluating;
      this.$evaluateBtn.disabled =
        this.isTraining ||
        this.isGeneratingDataset ||
        this.state.isEvaluating ||
        this.state.epochsCompleted === 0;
      this.$evaluateMinimaxBtn.disabled =
        this.isTraining ||
        this.isGeneratingDataset ||
        this.state.isEvaluating ||
        this.state.epochsCompleted === 0;
      this.$trainingBadge.classList.toggle("hidden", !this.state.demoMode);
      this.$tests.classList.toggle("hidden", !this.state.debug);
      this.$evaluateBtn.classList.toggle("active", this.state.evalOpponent === "random");
      this.$evaluateMinimaxBtn.classList.toggle("active", this.state.evalOpponent === "minimax");
      this.renderBoard();
      this.renderStateBox();
      this.drawChart();
    }

    renderBoard() {
      this.$board.innerHTML = "";
      const boardToRender = this.state.demoMode ? this.state.demoBoard : this.state.board;
      const currentPlayer = this.state.demoMode ? this.state.demoCurrentPlayer : this.state.currentPlayer;
      const demoLocked = this.state.demoMode;
      const x = this.encodeBoard(boardToRender, "O");
      const probs = this.model.predict(x);
      const legal = this.getAvailableMoves(boardToRender);
      const bestModelMove = legal.length ? this.bestMoveModel(boardToRender, "O") : null;
      boardToRender.forEach((value, index) => {
        const btn = document.createElement("button");
        btn.className = "cell";
        btn.dataset.row = String(Math.floor(index / 3));
        btn.dataset.col = String(index % 3);
        if (!legal.includes(index)) btn.classList.add("cell-illegal");
        if (!value && index === bestModelMove) btn.classList.add("cell-choice");
        btn.textContent = value;
        btn.disabled = demoLocked || this.state.gameOver || !!value || currentPlayer !== this.state.humanSymbol;
        btn.addEventListener("click", () => this.handleHumanMove(index));
        const probLabel = document.createElement("span");
        probLabel.className = "cell-prob-label";
        probLabel.textContent = `${(probs[index] * 100).toFixed(0)}%`;
        btn.appendChild(probLabel);
        const probBar = document.createElement("div");
        probBar.className = "cell-prob";
        const probFill = document.createElement("span");
        probFill.className = "cell-prob-fill";
        probFill.style.width = `${(probs[index] * 100).toFixed(1)}%`;
        probBar.appendChild(probFill);
        btn.appendChild(probBar);
        this.$board.appendChild(btn);
      });
    }

    renderStateBox() {
      const boardForState = this.state.demoMode ? this.state.demoBoard : this.state.board;
      const currentPlayer = this.state.demoMode ? this.state.demoCurrentPlayer : this.state.currentPlayer;
      const winner = this.state.demoMode ? this.state.demoWinner : this.state.winner;
      const encoded = this.encodeBoard(boardForState, "O");
      const lines = [
        `board: [${boardForState.map((v) => v || ".").join(", ")}]`,
        `currentPlayer: ${currentPlayer}`,
        `encoded: [${encoded.map((v) => Number(v).toFixed(0)).join(", ")}]`,
        `legalMoves: [${this.getAvailableMoves(boardForState).join(", ")}]`,
        `winner: ${winner || this.t.none}`,
        `gameOver: ${this.state.demoMode ? !!winner : this.state.gameOver}`,
        `backend tfjs: ${tf.getBackend()}`,
        `datasetStorage: IndexedDB`,
        `datasetRowsPersisted: ${this.state.trainingSetPersistedCount}`,
        `datasetChunkCount: ${this.state.trainingChunkCount}`,
        `modelStorage: ${this.state.modelPersisted ? "IndexedDB" : this.t.memory}`,
        `modelSizeBytes: ${this.getModelSizeBytes()}`,
        `batchSize: ${this.state.batchSize}`,
        `batchProgress: ${this.state.currentBatch}/${this.state.totalBatches}`,
        `lastBatchEventAt: ${this.state.lastBatchEventAt || 0}`,
      ];
      this.$stateBox.textContent = lines.join("\n");
    }

    handleHumanMove(index) {
      if (this.state.gameOver || this.state.board[index]) return;
      this.ensureAudioContext();
      this.makeMove(index, "X");
      if (this.state.gameOver) return;
      queueMicrotask(() => this.aiTurn());
    }

    aiTurn() {
      if (this.state.gameOver) return;
      const move = this.bestMoveModel(this.state.board, "O");
      if (move == null) return;
      this.makeMove(move, "O");
    }

    makeMove(index, player) {
      this.state.board[index] = player;
      const winner = this.checkWinner(this.state.board);
      if (winner) {
        this.state.gameOver = true;
        this.state.winner = winner;
        this.state.status = winner === "draw" ? this.t.draw : this.t.winsGame(winner);
        this.maybePlayGameEndSound(winner);
      } else {
        this.state.currentPlayer = player === "X" ? "O" : "X";
        this.state.status = this.state.currentPlayer === "X" ? this.t.yourTurn : this.t.aiMoveTurn;
      }
      this.updateUI();
    }

    getAvailableMoves(board) {
      const out = [];
      for (let i = 0; i < board.length; i++) if (!board[i]) out.push(i);
      return out;
    }

    checkWinner(board) {
      const lines = [[0, 1, 2], [3, 4, 5], [6, 7, 8], [0, 3, 6], [1, 4, 7], [2, 5, 8], [0, 4, 8], [2, 4, 6]];
      for (const [a, b, c] of lines) {
        if (board[a] && board[a] === board[b] && board[b] === board[c]) return board[a];
      }
      return board.every(Boolean) ? "draw" : null;
    }

    otherPlayer(player) {
      return player === "X" ? "O" : "X";
    }

    minimax(board, current, maximizingPlayer, depth = 0) {
      const result = this.checkWinner(board);
      if (result) {
        if (result === maximizingPlayer) return 10 - depth;
        if (result === "draw") return 0;
        return depth - 10;
      }
      const moves = this.getAvailableMoves(board);
      const isMax = current === maximizingPlayer;
      let best = isMax ? -Infinity : Infinity;
      for (const move of moves) {
        board[move] = current;
        const score = this.minimax(board, this.otherPlayer(current), maximizingPlayer, depth + 1);
        board[move] = "";
        if (isMax) best = Math.max(best, score);
        else best = Math.min(best, score);
      }
      return best;
    }

    getImmediateWinningMoves(board, player) {
      const wins = [];
      const moves = this.getAvailableMoves(board);
      for (const move of moves) {
        board[move] = player;
        if (this.checkWinner(board) === player) wins.push(move);
        board[move] = "";
      }
      return wins;
    }

    bestMoveMinimax(board, player) {
      const moves = this.getAvailableMoves(board);
      if (!moves.length) return null;
      const immediateWins = this.getImmediateWinningMoves(board, player);
      if (immediateWins.length) return immediateWins[0];
      const opponent = this.otherPlayer(player);
      const forcedBlocks = this.getImmediateWinningMoves(board, opponent);
      if (forcedBlocks.length) return forcedBlocks[0];
      let bestScore = -Infinity;
      let bestMove = moves[0];
      for (const move of moves) {
        board[move] = player;
        const score = this.minimax(board, opponent, player, 1);
        board[move] = "";
        if (score > bestScore) {
          bestScore = score;
          bestMove = move;
        }
      }
      return bestMove;
    }

    encodeBoard(board, playerToMove = "O") {
      const current = board.map((cell) => (cell === "X" ? -1 : cell === "O" ? 1 : 0));
      current.push(playerToMove === "O" ? 1 : -1);
      return current;
    }

    bestMoveModel(board, player = "O") {
      const probs = this.model.predict(this.encodeBoard(board, player));
      const legal = this.getAvailableMoves(board);
      let bestMove = legal[0] ?? null;
      let bestScore = -Infinity;
      for (const move of legal) {
        if (probs[move] > bestScore) {
          bestScore = probs[move];
          bestMove = move;
        }
      }
      return bestMove;
    }

    sampleMoveModel(board, player = "O", temperature = 0.9) {
      const probs = this.model.predict(this.encodeBoard(board, player));
      const legal = this.getAvailableMoves(board);
      if (!legal.length) return null;
      const scaled = legal.map((move) =>
        Math.pow(Math.max(probs[move], 1e-6), 1 / temperature),
      );
      const total = scaled.reduce((sum, value) => sum + value, 0) || 1;
      let threshold = Math.random() * total;
      for (let i = 0; i < legal.length; i++) {
        threshold -= scaled[i];
        if (threshold <= 0) return legal[i];
      }
      return legal[legal.length - 1];
    }

    isValidStateForOTurn(board) {
      const xCount = board.filter((cell) => cell === "X").length;
      const oCount = board.filter((cell) => cell === "O").length;
      return xCount === oCount + 1 && !this.checkWinner(board);
    }

    randomIntLocal(max) {
      return Math.floor(Math.random() * max);
    }

    boardKeyLocal(board) {
      return board.join("|");
    }

    buildLocalSampleFromBoard(board) {
      const legal = this.getAvailableMoves(board);
      if (!legal.length) return null;
      const moveScores = legal.map((move) => {
        board[move] = "O";
        const score = this.minimax(board, "X", "O", 1);
        board[move] = "";
        return { move, score };
      });
      const bestScore = Math.max(...moveScores.map((entry) => entry.score));
      const bestMoves = moveScores.filter((entry) => entry.score === bestScore).map((entry) => entry.move);
      if (!bestMoves.length) return null;
      const target = Array(9).fill(0);
      const weight = 1 / bestMoves.length;
      bestMoves.forEach((move) => {
        target[move] = weight;
      });
      return {
        x: this.encodeBoard(board, "O"),
        y: bestMoves[0],
        target,
        board: board.slice(),
        bestMoveCount: bestMoves.length,
        bestScore,
      };
    }

    generateRandomValidBoardForOTurnLocal(maxPlies = 5) {
      const board = Array(9).fill("");
      let current = "X";
      const pliesOptions = [1, 3, 5];
      const plies = pliesOptions[this.randomIntLocal(pliesOptions.length)];
      for (let step = 0; step < Math.min(maxPlies, plies); step++) {
        const winner = this.checkWinner(board);
        if (winner) break;
        const options = this.getAvailableMoves(board);
        if (!options.length) break;
        const move = options[this.randomIntLocal(options.length)] ?? null;
        if (move == null) break;
        board[move] = current;
        current = this.otherPlayer(current);
      }
      return this.isValidStateForOTurn(board) ? board : null;
    }

    createLocalTacticalBoards(limit = 300) {
      const boards = [];
      const seen = new Set();
      let attempts = 0;
      const maxAttempts = limit * 80;
      while (boards.length < limit && attempts < maxAttempts) {
        attempts += 1;
        const board = this.generateRandomValidBoardForOTurnLocal(5);
        if (!board) continue;
        const sample = this.buildLocalSampleFromBoard(board.slice());
        const opponentWins = this.getImmediateWinningMoves(board.slice(), "X");
        const selfWins = this.getImmediateWinningMoves(board.slice(), "O");
        const isTactical =
          selfWins.length > 0 || opponentWins.length > 0 || (sample && sample.bestMoveCount === 1);
        const key = this.boardKeyLocal(board);
        if (!isTactical || seen.has(key)) continue;
        seen.add(key);
        boards.push(board.slice());
      }
      return boards;
    }

    generateTrainingDataLocal(count = 40) {
      const targetCount = Math.max(12, count);
      const samples = [];
      const seen = new Set();
      const tacticalBoards = this.createLocalTacticalBoards(
        Math.min(200, Math.max(24, Math.floor(targetCount * 0.35))),
      );
      for (let i = tacticalBoards.length - 1; i > 0; i--) {
        const j = this.randomIntLocal(i + 1);
        [tacticalBoards[i], tacticalBoards[j]] = [tacticalBoards[j], tacticalBoards[i]];
      }
      const tacticalQuota = Math.min(tacticalBoards.length, Math.max(12, Math.floor(targetCount * 0.35)));

      for (let i = 0; i < tacticalQuota && samples.length < targetCount; i++) {
        const board = tacticalBoards[i].slice();
        const key = this.boardKeyLocal(board);
        if (seen.has(key)) continue;
        const sample = this.buildLocalSampleFromBoard(board);
        if (!sample) continue;
        seen.add(key);
        samples.push(sample);
      }

      let attempts = 0;
      const maxAttempts = targetCount * 40;
      while (samples.length < targetCount && attempts < maxAttempts) {
        attempts += 1;
        const board = this.generateRandomValidBoardForOTurnLocal();
        if (!board) continue;
        const key = this.boardKeyLocal(board);
        if (seen.has(key)) continue;
        const sample = this.buildLocalSampleFromBoard(board);
        if (!sample) continue;
        seen.add(key);
        samples.push(sample);
      }

      for (let i = samples.length - 1; i > 0; i--) {
        const j = this.randomIntLocal(i + 1);
        [samples[i], samples[j]] = [samples[j], samples[i]];
      }
      return samples.slice(0, targetCount);
    }

    stopDemoPlayback() {
      if (this.demoTimer) {
        cancelAnimationFrame(this.demoTimer);
        this.demoTimer = null;
      }
      this.state.demoMode = false;
      this.state.demoBoard = Array(9).fill("");
      this.state.demoCurrentPlayer = "X";
      this.state.demoWinner = null;
      this.state.demoShouldFinishCycle = false;
    }

    scheduleDemoStep(next) {
      this.demoTimer = requestAnimationFrame(() => {
        this.demoTimer = null;
        next();
      });
    }

    playTrainingDemo(finishCycle = false) {
      const startingFresh = !this.state.demoMode;
      if (startingFresh) {
        this.stopDemoPlayback();
        this.state.demoMode = true;
        this.state.demoBoard = Array(9).fill("");
        this.state.demoCurrentPlayer = "X";
        this.state.demoWinner = null;
      }
      this.state.demoShouldFinishCycle = finishCycle || this.state.demoShouldFinishCycle;
      const step = () => {
        if (!this.state.demoMode) return;
        const winner = this.checkWinner(this.state.demoBoard);
        if (winner) {
          this.state.demoWinner = winner;
          this.updateUI();
          if (this.isTraining) {
            this.scheduleDemoStep(() => {
              this.state.demoBoard = Array(9).fill("");
              this.state.demoCurrentPlayer = "X";
              this.state.demoWinner = null;
              this.updateUI();
              step();
            });
          } else if (this.state.demoShouldFinishCycle) {
            this.state.demoShouldFinishCycle = false;
            this.scheduleDemoStep(() => {
              this.stopDemoPlayback();
              this.updateUI();
            });
          } else {
            this.stopDemoPlayback();
            this.updateUI();
          }
          return;
        }
        const player = this.state.demoCurrentPlayer;
        let move;
        if (player === "O") move = this.sampleMoveModel(this.state.demoBoard, "O");
        else {
          const options = this.getAvailableMoves(this.state.demoBoard);
          move = options[Math.floor(Math.random() * options.length)] ?? null;
        }
        if (move == null) {
          this.state.demoWinner = "draw";
          this.updateUI();
          if (this.isTraining) {
            this.scheduleDemoStep(() => {
              this.state.demoBoard = Array(9).fill("");
              this.state.demoCurrentPlayer = "X";
              this.state.demoWinner = null;
              this.updateUI();
              step();
            });
          } else if (this.state.demoShouldFinishCycle) {
            this.state.demoShouldFinishCycle = false;
            this.scheduleDemoStep(() => {
              this.stopDemoPlayback();
              this.updateUI();
            });
          }
          return;
        }
        this.state.demoBoard[move] = player;
        this.state.demoCurrentPlayer = player === "X" ? "O" : "X";
        this.updateUI();
        this.scheduleDemoStep(step);
      };
      this.updateUI();
      if (!this.demoTimer) this.scheduleDemoStep(step);
    }

    runEvaluation(opponent = "random") {
      if (
        this.state.isEvaluating ||
        this.isTraining ||
        this.isGeneratingDataset ||
        this.state.epochsCompleted === 0
      ) {
        return;
      }
      this.state.isEvaluating = true;
      this.state.evalOpponent = opponent;
      this.state.status = this.t.evaluatingAgainst(opponent);
      this.updateUI();
      this.evaluationWorker = this.createWorker();
      this.evaluationWorker.onmessage = (event) => {
        const { type, tally, opponent: resultOpponent } = event.data;
        if (type === "evaluation-finished") {
          this.state.eval = tally;
          this.state.evalOpponent = resultOpponent;
          this.state.isEvaluating = false;
          this.$evalLabel.textContent = resultOpponent === "random" ? this.t.vsRandom : this.t.vsMinimax;
          this.state.status = this.t.evaluationCompleted(resultOpponent);
          if (this.evaluationWorker) {
            this.evaluationWorker.terminate();
            this.evaluationWorker = null;
          }
          this.updateUI();
        }
      };
      this.evaluationWorker.postMessage({
        type: "evaluate",
        opponent,
        rounds: 80,
        modelState: this.model.getState(),
      });
    }

    drawChart() {
      const ctx = this.ctx;
      const w = this.$chart.width;
      const h = this.$chart.height;
      ctx.clearRect(0, 0, w, h);
      ctx.fillStyle = "rgba(255,255,255,0.04)";
      ctx.fillRect(0, 0, w, h);
      for (let i = 1; i <= 4; i++) {
        const y = (h / 5) * i;
        ctx.strokeStyle = "rgba(255,255,255,0.08)";
        ctx.beginPath();
        ctx.moveTo(0, y);
        ctx.lineTo(w, y);
        ctx.stroke();
      }
      this.drawSeries(this.state.losses, "#38bdf8", 0, Math.max(1.5, ...this.state.losses, 0.1));
      this.drawSeries(this.state.accuracies, "#22c55e", 0, 1);
    }

    drawSeries(series, color, min, max) {
      if (!series.length) return;
      const ctx = this.ctx;
      const w = this.$chart.width;
      const h = this.$chart.height;
      ctx.strokeStyle = color;
      ctx.lineWidth = 2;
      ctx.beginPath();
      series.forEach((value, index) => {
        const x = series.length === 1 ? 0 : (index / (series.length - 1)) * w;
        const t = (value - min) / (max - min || 1);
        const y = h - t * (h - 10) - 5;
        if (index === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      });
      ctx.stroke();
    }

    runSelfTests() {
      const results = [];
      const assert = (name, condition) => {
        if (!condition) throw new Error(name);
        results.push(`✓ ${name}`);
      };
      assert("encodeBoard devuelve 10 valores", this.encodeBoard(Array(9).fill(""), "O").length === 10);
      assert("checkWinner detecta fila ganadora", this.checkWinner(["X", "X", "X", "", "", "", "", "", ""]) === "X");
      assert("checkWinner detecta empate", this.checkWinner(["X", "O", "X", "X", "O", "O", "O", "X", "X"]) === "draw");
      assert("minimax bloquea amenaza inmediata", this.bestMoveMinimax(["X", "X", "", "", "", "", "", "", ""], "O") === 2);
      assert("minimax juega victoria inmediata si existe", this.bestMoveMinimax(["O", "O", "", "X", "", "X", "", "", ""], "O") === 2);
      const localDataset = this.generateTrainingDataLocal(24);
      assert("generateTrainingDataLocal genera suficientes ejemplos", localDataset.length >= 12);
      assert("existe un pool táctico local útil", this.createLocalTacticalBoards(120).length >= 12);
      assert("dataset local contiene estados válidos", localDataset.every((sample) => this.isValidStateForOTurn(sample.board)));
      assert("dataset local contiene targets legales", localDataset.every((sample) => this.getAvailableMoves(sample.board).includes(sample.y)));
      assert("dataset local incluye targets distribuidos", localDataset.every((sample) => Array.isArray(sample.target) && sample.target.length === 9 && sample.target.reduce((sum, value) => sum + value, 0) > 0.99));
      assert("dataset local incluye casos tácticos o de mejor jugada única", localDataset.some((sample) => sample.bestMoveCount === 1 || sample.bestScore > 0));
      this.state.demoMode = true;
      this.state.demoBoard = ["X", "", "", "", "O", "", "", "", ""];
      assert("bestMoveModel devuelve una casilla legal", this.getAvailableMoves(this.state.demoBoard).includes(this.bestMoveModel(this.state.demoBoard, "O")));
      this.renderStateBox();
      assert("renderStateBox incluye saltos de línea válidos", this.$stateBox.textContent.includes("\n"));
      this.renderBoard();
      assert("el tablero renderiza overlays", this.$board.querySelectorAll(".cell-prob-label").length === 9);
      this.state.evalOpponent = "minimax";
      this.updateUI();
      assert("el botón minimax se marca como activo", this.$evaluateMinimaxBtn.classList.contains("active"));
      assert("la partida manual usa siempre el modelo", this.$aiLabel.textContent === "Modelo");
      this.stopDemoPlayback();
      assert("stopDemoPlayback apaga el modo demo", this.state.demoMode === false);
      this.state.epochsCompleted = 1;
      this.state.isEvaluating = true;
      this.updateUI();
      assert("los botones de evaluar se desactivan mientras evalúa", this.$evaluateBtn.disabled && this.$evaluateMinimaxBtn.disabled);
      this.state.isEvaluating = false;
      this.updateUI();
      assert("los botones vuelven a activarse", !this.$evaluateBtn.disabled && !this.$evaluateMinimaxBtn.disabled);
      assert("sampleMoveModel devuelve una casilla legal", this.getAvailableMoves(Array(9).fill("")).includes(this.sampleMoveModel(Array(9).fill(""), "O")));
      assert("el modelo tfjs devuelve 9 probabilidades", this.model.predict(this.encodeBoard(Array(9).fill(""), "O")).length === 9);
      assert("el tamaño del modelo es positivo", this.getModelSizeBytes() > 0);
      assert("batchSize inicial es válido", this.state.batchSize >= 16);
      this.state.totalBatches = 11;
      this.state.currentBatch = 3;
      this.updateUI();
      assert("el contador de batch refleja el progreso", this.$batchCounter.textContent === "3/11");
      this.state.lastBatchEventAt = 123;
      this.renderStateBox();
      assert("stateBox refleja último evento batch", this.$stateBox.textContent.includes("lastBatchEventAt: 123"));
      assert("el estado inicial de batch puede ser 0", this.$batchCounter.textContent.includes("/"));
      this.trainingWorker = null;
      assert("trainingWorker puede ser null sin romper tests", this.trainingWorker === null);
      this.state.demoMode = false;
      this.state.isEvaluating = false;
      this.isTraining = false;
      this.isGeneratingDataset = false;
      assert("no suena en empate ni en modos automáticos", true);
      this.$tests.textContent = this.state.debug ? results.join(" · ") : "";
    }
  }

  if (!customElements.get("tic-tac-toe-ml")) {
    customElements.define("tic-tac-toe-ml", TicTacToeML);
  }
</script>
